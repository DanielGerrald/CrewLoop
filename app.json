{
  "expo": {
    "name": "CrewLoop",
    "slug": "crewloop",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#1E2530"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.crewloop.fieldops",
      "minimumOsVersion": "16.0",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "LSApplicationQueriesSchemes": [
          "comgooglemaps",
          "waze"
        ]
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": ""
      }
    },
    "android": {
      "minSdkVersion": 24,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ],
      "package": "com.crewloop.fieldops",
      "softwareKeyboardLayoutMode": "pan"
    },
    "plugins": [
      "expo-asset",
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ],
      [
        "expo-sqlite",
        {
          "enableFTS": true,
          "useSQLCipher": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you upload them to the work order.",
          "cameraPermission": "The app accesses your camera so you can take photos to upload to the work order."
        }
      ],
      "expo-web-browser",
      "expo-font",
      "expo-image",
      "expo-sharing"
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
